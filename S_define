

#include "sim_objects/default_trick_sys.sm"

##include "models/ball/include/ball.h"

class BallSimObject : public Trick::SimObject {
    public:
        ayBall ball;
        BallSimObject() {
            ("initialization") ay_bounce_init( &ball );
            ("derivative")     ay_force( &ball );
            ("integration")    trick_ret = ay_integrate( &ball );
            ("dynamic_event")  ay_impact( &ball );
        }
};

BallSimObject ball_sim;

IntegLoop ball_integloop (0.01) ball_sim;

void create_connections() {
    ball_integloop.getIntegrator(Runge_Kutta_4, 5);
}